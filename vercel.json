{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/landing",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/login/_auth/:path*",
      "destination": "https://hoinam-energy-workspace.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/auth/:path*",
      "destination": "https://hoinam-energy-workspace.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/init.json",
      "destination": "https://hoinam-energy-workspace.firebaseapp.com/__/firebase/init.json"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
